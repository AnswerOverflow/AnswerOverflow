# .env.example for AnswerOverflow

# ========================
# Environment & Node.js
# ========================
NODE_ENV=production  # or development

# ========================
# Deployment & Convex (Required for backend)
# ========================
CONVEX_DEPLOYMENT=your-project.convex.cloud  
CONVEX_DEPLOY_KEY=your-convex-deploy-key  # From Convex dashboard > Settings > Deployment
CONVEX_SITE_URL=https://your-project.convex.site  # Server URL (private)
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.site  # Client URL (public)
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-project.convex.site  # Server URL (public)
NEXT_PUBLIC_DEPLOYMENT_ENV=production  # or development

# Vercel (if deploying there)
PROJECT_ID_VERCEL=prj_...
TEAM_ID_VERCEL=team_...
AUTH_BEARER_TOKEN_VERCEL=vercel_auth_token_here

# ========================
# Discord Bot & Auth (Required for bot)
# ========================
DISCORD_TOKEN=your_bot_token_here  # Discord bot token
DISCORD_BOT_TOKEN=your_bot_token_here  # Same as DISCORD_TOKEN
DISCORD_CLIENT_ID=123456789012345678  # OAuth2 app client ID
DISCORD_CLIENT_SECRET=your_client_secret  # OAuth2 app secret
NEXT_PUBLIC_DISCORD_CLIENT_ID=123456789012345678  # Public client ID
DISCORD_E2E_TOKEN=selfbot_token_for_tests  # E2E testing

# ========================
# GitHub Integration (OAuth + Scripts)
# ========================
GITHUB_TOKEN=ghp_...  # Personal access token for scripts
GITHUB_CLIENT_ID=your_github_oauth_client_id  # GitHub OAuth client ID
GITHUB_CLIENT_SECRET=your_github_oauth_secret  # GitHub OAuth client secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# ========================
# Authentication (Better Auth + Convex)
# ========================
BETTER_AUTH_SECRET=your_32+char_random_secret  # Generate with openssl rand -base64 32
SITE_URL=https://www.answeroverflow.com  # Site URL for authentication

# ========================
# Stripe Billing (Optional for payments)
# ========================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PLAN_PRICE_ID=price_...
STRIPE_ADVANCED_PLAN_PRICE_ID=price_...
STRIPE_PRO_PLAN_LEGACY_PRICE_ID=price_...
STRIPE_ENTERPRISE_PLAN_LEGACY_PRICE_ID=price_...
STRIPE_CHECKOUT_URL=https://checkout.stripe.com/...
STRIPE_USER_WEBHOOK_SECRET=whsec_user_...  # user plans
STRIPE_USER_PRO_PRICE_ID=price_user_pro 

# ========================
# Observability & Analytics
# ========================
NEXT_PUBLIC_SENTRY_DSN=https://public_key@oorg.ing/...  # Client-side Sentry
SENTRY_DSN=https://private_key@oorg.ing/...  # Server-side Sentry
SENTRY_RELEASE=version_or_commit_hash  # Sentry release version
NEXT_PUBLIC_POSTHOG_TOKEN=phc_...
POSTHOG_PERSONAL_API_KEY=phc_personal_...
POSTHOG_PROJECT_ID=PROJECT_123
AXIOM_API_TOKEN=xait_...
AXIOM_DOMAIN=api.axiom.co  # Axiom domain
AXIOM_TRACES_DATASET=discord-bot-traces  # OpenTelemetry traces dataset
AXIOM_LOGS_DATASET=discord-bot-logs  # Application logs dataset
AXIOM_METRICS_DATASET=discord-bot-metrics  # Metrics dataset
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces  # OpenTelemetry endpoint
NEXT_PUBLIC_ANALYTICS_PATH=a  # PostHog analytics path

# ========================
# AWS S3 / Storage (Optional)
# ========================
BUCKET_NAME=your-s3-bucket
IAM_USER_KEY=your_aws_access_key_id
IAM_USER_SECRET=your_aws_secret_access_key

# ========================
# Links & URLs
# ========================
NEXT_PUBLIC_BASE_URL=https://www.answeroverflow.com
NEXT_PUBLIC_GITHUB_APP_INSTALL_URL=https://github.com/apps/answer-overflow/installations/new
NEXT_PUBLIC_SITE_URL=https://www.answeroverflow.com
CDN_DOMAIN=cdn.answeroverflow.com

# ========================
# AI Providers (Optional, for agent/ai pkg)
# ========================
ANTHROPIC_API_KEY=anth_...

# ========================
# Backend & Internal
# ========================
BACKEND_ACCESS_TOKEN=your_backend_token  # Server-to-server authentication
PUBLIC_BACKEND_ACCESS_TOKEN=your_public_backend_token  # Public backend API access

# ========================
# Feature Flags
# ========================
ALLOW_HARD_DELETE=false  # Allow hard delete operations in database (development only)

# ========================
# Other / Misc
# ========================
STATUS_UPDATE_INTERVAL_IN_HOURS=1  # Bot status update interval


